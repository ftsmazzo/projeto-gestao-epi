generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ServedClientStatus {
  ACTIVE
  INACTIVE
}

enum OperationalUnitStatus {
  ACTIVE
  INACTIVE
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

/// Empresa usuaria do software (tenant). Nao e cliente atendido nem unidade operacional.
model Organization {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  /// Franquia total de vidas contratadas (preparacao para billing/cotas futuras).
  contractedLifeQuota Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships       Membership[]
  auditLogs         AuditLog[]
  servedClients     ServedClient[]
  operationalUnits  OperationalUnit[]
  workers           Worker[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
  auditLogs   AuditLog[]
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(OWNER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

/// Cliente atendido pelo tenant. Distinto de Organization e de OperationalUnit.
model ServedClient {
  id                 String             @id @default(cuid())
  organizationId     String
  legalName          String
  tradeName          String?
  /// CNPJ apenas digitos (14).
  cnpj               String
  status             ServedClientStatus @default(ACTIVE)
  allocatedLifeQuota Int                @default(0)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operationalUnits OperationalUnit[]
  workers          Worker[]

  @@unique([organizationId, cnpj])
  @@index([organizationId])
  @@index([status])
}

/// Unidade operacional do cliente atendido (filial, obra, planta, local de entrega).
model OperationalUnit {
  id             String                @id @default(cuid())
  organizationId String
  servedClientId String
  name           String
  code           String?
  status         OperationalUnitStatus @default(ACTIVE)
  addressLine    String?
  city           String?
  state          String?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  servedClient ServedClient @relation(fields: [servedClientId], references: [id], onDelete: Cascade)
  workers      Worker[]

  @@unique([servedClientId, code])
  @@index([organizationId])
  @@index([servedClientId])
  @@index([status])
}

/// Trabalhador (vida) vinculado a um cliente atendido e opcionalmente a uma unidade.
model Worker {
  id                 String       @id @default(cuid())
  organizationId     String
  servedClientId     String
  operationalUnitId  String?
  name               String
  /// CPF apenas digitos (11), opcional.
  cpf                String?
  /// Matricula/codigo interno, unico por cliente quando informado.
  registration       String?
  role               String?
  department         String?
  status             WorkerStatus @default(ACTIVE)
  admissionDate      DateTime?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  servedClient    ServedClient     @relation(fields: [servedClientId], references: [id], onDelete: Cascade)
  operationalUnit OperationalUnit? @relation(fields: [operationalUnitId], references: [id], onDelete: SetNull)

  @@unique([organizationId, cpf])
  @@unique([servedClientId, registration])
  @@index([organizationId])
  @@index([servedClientId])
  @@index([operationalUnitId])
  @@index([status])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
