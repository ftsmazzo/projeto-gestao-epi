generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ServedClientStatus {
  ACTIVE
  INACTIVE
}

/// Empresa usuaria do software (tenant). Nao e cliente atendido nem unidade operacional.
model Organization {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  /// Franquia total de vidas contratadas (preparacao para billing/cotas futuras).
  contractedLifeQuota Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships   Membership[]
  auditLogs     AuditLog[]
  servedClients ServedClient[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
  auditLogs   AuditLog[]
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(OWNER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

/// Cliente atendido pelo tenant. Distinto de Organization e de Unit operacional.
model ServedClient {
  id                 String             @id @default(cuid())
  organizationId     String
  legalName          String
  tradeName          String?
  /// CNPJ apenas digitos (14).
  cnpj               String
  status             ServedClientStatus @default(ACTIVE)
  allocatedLifeQuota Int                @default(0)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, cnpj])
  @@index([organizationId])
  @@index([status])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
