generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ServedClientStatus {
  ACTIVE
  INACTIVE
}

enum OperationalUnitStatus {
  ACTIVE
  INACTIVE
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

enum EpiUnitOfMeasure {
  UNIDADE
  PAR
  CAIXA
  KIT
}

enum EpiUsefulLifeUnit {
  DIAS
  MESES
  ANOS
}

enum EpiCategory {
  AUDITIVA
  RESPIRATORIA
  QUEDA
  MAOS
  OLHOS
  CABECA
  PES
  TRONCO
  OUTROS
}

/// Empresa usuaria do software (tenant). Nao e cliente atendido nem unidade operacional.
model Organization {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  /// Franquia total de vidas contratadas (preparacao para billing/cotas futuras).
  contractedLifeQuota Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships       Membership[]
  auditLogs         AuditLog[]
  servedClients     ServedClient[]
  operationalUnits  OperationalUnit[]
  workers           Worker[]
  epiItems          EpiItem[]
  epiVariants       EpiVariant[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
  auditLogs   AuditLog[]
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(OWNER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

/// Cliente atendido pelo tenant. Distinto de Organization e de OperationalUnit.
model ServedClient {
  id                 String             @id @default(cuid())
  organizationId     String
  legalName          String
  tradeName          String?
  /// CNPJ apenas digitos (14).
  cnpj               String
  status             ServedClientStatus @default(ACTIVE)
  allocatedLifeQuota Int                @default(0)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operationalUnits OperationalUnit[]
  workers          Worker[]

  @@unique([organizationId, cnpj])
  @@index([organizationId])
  @@index([status])
}

/// Unidade operacional do cliente atendido (filial, obra, planta, local de entrega).
model OperationalUnit {
  id             String                @id @default(cuid())
  organizationId String
  servedClientId String
  name           String
  code           String?
  /// CNPJ opcional da filial/unidade (normalizado, sem mascara). Pode coincidir com o CNPJ do cliente.
  cnpj           String?
  status         OperationalUnitStatus @default(ACTIVE)
  addressLine    String?
  city           String?
  state          String?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  servedClient ServedClient @relation(fields: [servedClientId], references: [id], onDelete: Cascade)
  workers      Worker[]

  @@unique([servedClientId, code])
  @@unique([organizationId, cnpj])
  @@index([organizationId])
  @@index([servedClientId])
  @@index([status])
}

/// Trabalhador (vida) vinculado a um cliente atendido e opcionalmente a uma unidade.
model Worker {
  id                 String       @id @default(cuid())
  organizationId     String
  servedClientId     String
  operationalUnitId  String?
  name               String
  /// CPF apenas digitos (11), opcional.
  cpf                String?
  /// Matricula/codigo interno, unico por cliente quando informado.
  registration       String?
  role               String?
  department         String?
  status             WorkerStatus @default(ACTIVE)
  admissionDate      DateTime?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  servedClient    ServedClient     @relation(fields: [servedClientId], references: [id], onDelete: Cascade)
  operationalUnit OperationalUnit? @relation(fields: [operationalUnitId], references: [id], onDelete: SetNull)

  @@unique([organizationId, cpf])
  @@unique([servedClientId, registration])
  @@index([organizationId])
  @@index([servedClientId])
  @@index([operationalUnitId])
  @@index([status])
}

/// Item do catalogo mestre de EPI do tenant (ainda sem estoque/entrega).
model EpiItem {
  id               String             @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  isActive         Boolean            @default(true)
  requiresCa       Boolean            @default(true)
  /// Numero do CA normalizado (sem espacos). Unico por tenant quando informado.
  caNumber         String?
  caExpiresAt      DateTime?
  unitOfMeasure    EpiUnitOfMeasure   @default(UNIDADE)
  usefulLifeValue  Int?
  usefulLifeUnit   EpiUsefulLifeUnit?
  category         EpiCategory?
  externalCode     String?
  manufacturerName String?
  reference        String?
  color            String?
  approvedFor      String?
  restriction      String?
  technicalNotes   String?
  /// NRR (protecao auditiva), opcional.
  nrr              Float?
  /// NRRsf (protecao auditiva), opcional.
  nrrsf            Float?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants     EpiVariant[]

  @@unique([organizationId, caNumber])
  @@index([organizationId])
  @@index([isActive])
  @@index([category])
  @@index([externalCode])
}

/// Variacao/grade de um item do catalogo (tamanho, cor, modelo, lado).
model EpiVariant {
  id             String   @id @default(cuid())
  organizationId String
  epiItemId      String
  size           String?
  color          String?
  model          String?
  side           String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  epiItem      EpiItem      @relation(fields: [epiItemId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([epiItemId])
  @@index([isActive])
}

enum CaCertificateStatus {
  VALIDO
  VENCIDO
  CANCELADO
  SUSPENSO
  DESCONHECIDO
}

enum CaCertificateSource {
  CAEPI_OFICIAL
}

/// Certificado de Aprovacao da base oficial CAEPI (global, nao por tenant).
model CaCertificate {
  id                   String              @id @default(cuid())
  /// Numero do CA normalizado, sem espacos. Unico globalmente.
  caNumber             String              @unique
  expiresAt            DateTime?
  status               CaCertificateStatus @default(DESCONHECIDO)
  processNumber        String?
  manufacturerCnpj     String?
  manufacturerName     String?
  nature               String?
  equipmentName        String?
  equipmentDescription String?
  brand                String?
  reference            String?
  color                String?
  approvedFor          String?
  restriction          String?
  analysisNotes        String?
  source               CaCertificateSource @default(CAEPI_OFICIAL)
  sourceImportedAt     DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  norms CaCertificateNorm[]

  @@index([status])
  @@index([manufacturerCnpj])
  @@index([expiresAt])
  @@index([equipmentName])
  @@index([manufacturerName])
  @@index([reference])
}

/// Norma/laudo associado a um CA (um CA pode ter varias linhas na base CAEPI).
model CaCertificateNorm {
  id              String   @id @default(cuid())
  certificateId   String
  laboratoryCnpj  String?
  laboratoryName  String?
  reportNumber    String?
  standard        String?
  createdAt       DateTime @default(now())

  certificate CaCertificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([certificateId, laboratoryCnpj, reportNumber, standard])
  @@index([certificateId])
  @@index([standard])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
