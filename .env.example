# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL (EasyPanel ou local) - nunca commitar segredos reais
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Auth JWT - use um segredo forte em producao
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS: URL(s) do front separadas por virgula. Use * apenas em desenvolvimento.
CORS_ORIGIN=http://localhost:3000

# CAEPI
# CAEPI_SOURCE_URL e OPCIONAL: apenas override tecnico.
# Em operacao normal o sistema usa fontes oficiais padrao (gov.br + FTP MTPS).
# Nao e necessario configurar URL para o cliente atualizar a base.
# CAEPI_SOURCE_URL=
CAEPI_AUTO_SYNC_ENABLED=false
# Cron padrao: 03:00 no dia 1 de cada mes
CAEPI_SYNC_CRON=0 3 1 * *

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3000
